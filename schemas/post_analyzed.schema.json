{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "post_analyzed.schema.json",
  "title": "PostAnalyzed",
  "type": "object",
  "required": [
    "id", "platform", "text", "clean_text", "time", "city", "geo",
    "intent", "emotion", "entities", "mapped_need", "urgency_score", "meta"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "platform": { "type": "string" },
    "text": { "type": "string" },
    "clean_text": { "type": "string" },
    "time": { "type": "string" },
    "city": { "type": "string", "const": "北京" },
    "geo": {
      "type": "object",
      "required": ["raw", "poi", "district", "confidence"],
      "additionalProperties": false,
      "properties": {
        "raw": { "type": ["string", "null"] },
        "poi": { "type": ["string", "null"] },
        "district": { "type": ["string", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "intent": { "type": "string", "enum": ["抱怨", "建议", "询问", "其他"] },
    "emotion": { "type": "string", "enum": ["不满", "焦虑", "期待", "中性"] },
    "entities": {
      "type": "object",
      "required": ["facility", "location"],
      "additionalProperties": false,
      "properties": {
        "facility": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mapped_need": {
      "type": "object",
      "required": ["need_id", "need_name_zh", "facility_scope", "rule_id"],
      "additionalProperties": false,
      "properties": {
        "need_id": { "type": ["string", "null"] },
        "need_name_zh": { "type": ["string", "null"] },
        "facility_scope": {
          "type": ["string", "null"],
          "enum": ["road_lighting", "public_charging", "public_transit", null]
        },
        "rule_id": { "type": ["string", "null"] }
      }
    },
    "urgency_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "meta": {
      "type": "object",
      "required": ["lab1_version", "lab2_version"],
      "additionalProperties": false,
      "properties": {
        "lab1_version": { "type": "string" },
        "lab2_version": { "type": "string" },
        "facility_scope_hint": {
          "type": ["string", "null"],
          "enum": ["road_lighting", "public_charging", "public_transit", null]
        }
      }
    }
  }
}
